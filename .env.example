# ================================================================
# MONEXA — Environment Variables
# ================================================================
# Cách lấy API keys:
#  1. Copy file này thành .env
#  2. Điền các giá trị theo hướng dẫn bên dưới
#  3. KHÔNG bao giờ commit file .env lên GitHub!
# ================================================================

# ── SUPABASE (BẮT BUỘC) ──────────────────────────────────────
# Lấy từ: https://supabase.com/dashboard → Project Settings → API
# URL Project:
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon Key (public, dùng phía frontend):
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── GROQ AI (BẮT BUỘC cho chatbot) ───────────────────────────
# Lấy từ: https://console.groq.com/keys
# Đăng ký free tier → tạo API key
# Free tier: 30 requests/minute, dùng model llama-3.3-70b-versatile
VITE_GROQ_API_KEY=gsk_your-groq-key-here

# ── GEMINI (Tuỳ chọn) ─────────────────────────────────────
# Lấy từ: https://aistudio.google.com/app/apikey
# Dùng làm backup LLM hoặc feature mở rộng
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# ── FIGMA (Tuỳ chọn) ─────────────────────────────────────
# Lấy từ: https://www.figma.com/developers/api#access-tokens
# Personal Access Token: Figma → Settings → Account → Personal Access Tokens
VITE_FIGMA_ACCESS_TOKEN=figd_your-figma-token-here

# File Key: Copy từ URL Figma file
# Ví dụ: https://www.figma.com/file/ABC123xyz → file_key = ABC123xyz
VITE_FIGMA_FILE_KEY=your-figma-file-key-here
